{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/services/", "destination": "/services" },
    { "source": "/operator/", "destination": "/operator" },
    { "source": "/browser-test/", "destination": "/browser-test" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}